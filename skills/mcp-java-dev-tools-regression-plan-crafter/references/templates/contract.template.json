{
  "targets": [
    {
      "type": "class_method",
      "selectors": {
        "fqcn": "com.example.app.controller.ExampleController",
        "method": "createExample",
        "signature": "(com.example.api.CreateExampleRequest)",
        "sourceRoot": "<module-source-root>"
      }
    }
  ],
  "prerequisites": [
    {
      "key": "tenantId",
      "required": true,
      "secret": false,
      "provisioning": "discoverable",
      "discoverySource": "datasource",
      "default": "tenant-default"
    },
    {
      "key": "auth.bearer",
      "required": true,
      "secret": true,
      "provisioning": "user_input"
    }
  ],
  "steps": [
    {
      "order": 1,
      "id": "create_entity",
      "targetRef": 0,
      "protocol": "http",
      "transport": {
        "http": {
          "method": "POST",
          "pathTemplate": "/api/v1/examples",
          "query": {
            "tenantId": "${tenantId}"
          },
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "name": "Example Name"
          }
        }
      },
      "extract": [
        {
          "from": "response.body.id",
          "as": "exampleId"
        }
      ],
      "expect": [
        {
          "id": "create_entity_outcome",
          "actualPath": "status",
          "operator": "outcome_status",
          "expected": "pass"
        }
      ]
    }
  ],
  "watchers": [
    {
      "id": "wait_for_downstream_completion",
      "dependency": {
        "stepOrder": 1
      },
      "provider": {
        "type": "http",
        "transport": {
          "request": {
            "method": "GET",
            "url": "${downstreamBaseUrl}/status/${exampleId}"
          }
        }
      },
      "waitPolicy": {
        "timeoutMs": 15000,
        "retryMax": 10
      },
      "expect": [
        {
          "id": "downstream_ready",
          "actualPath": "response.bodyJson.status",
          "operator": "field_equals",
          "expected": "ready"
        }
      ]
    }
  ],
  "externalVerification": [
    {
      "id": "verify_downstream_record",
      "provider": {
        "type": "http"
      },
      "request": {
        "http": {
          "method": "GET",
          "url": "${verificationBaseUrl}/records/${exampleId}"
        }
      },
      "expect": [
        {
          "id": "verification_http_ok",
          "actualPath": "response.statusCode",
          "operator": "field_equals",
          "expected": 200
        }
      ]
    }
  ]
}
