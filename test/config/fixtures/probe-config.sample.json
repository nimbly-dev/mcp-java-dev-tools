{
  "defaultProfile": "dev",
  "workspaces": [
    { "root": "C:\\workspace\\orders-platform", "profile": "dev" },
    { "root": "C:\\workspace\\orders-platform-prod", "profile": "prod" }
  ],
  "profiles": {
    "dev": {
      "global": {
        "allowNonWrappedExecutable": false,
        "probeLineSelectionMaxScanLines": 180,
        "probeWaitMaxRetries": 2,
        "probeWaitUnreachableRetryEnabled": true,
        "probeWaitUnreachableMaxRetries": 4,
        "probeIncludeExecutionPaths": false
      },
      "probes": {
        "order-service": {
          "baseUrl": "http://127.0.0.1:9190",
          "include": ["com.acme.orders.**"],
          "exclude": []
        },
        "auth-service": {
          "baseUrl": "http://127.0.0.1:9191",
          "include": ["com.acme.auth.**"],
          "exclude": ["com.acme.auth.generated.**"],
          "probeWaitMaxRetries": 3
        }
      }
    },
    "prod": {
      "probes": {
        "order-service": {
          "baseUrl": "http://127.0.0.1:9390",
          "include": ["com.acme.orders.**"],
          "exclude": []
        }
      }
    }
  }
}
