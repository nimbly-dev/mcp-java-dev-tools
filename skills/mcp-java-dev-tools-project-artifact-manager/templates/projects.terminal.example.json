{
  "workspaces": [
    {
      "projectRoot": "C:\\workspace\\spring-petclinic-microservices",
      "envFile": ".env",
      "variables": {
        "bearerTokenEnv": "AUTH_BEARER_TOKEN",
        "keycloakClientIdEnv": "KEYCLOAK_CLIENT_ID",
        "keycloakClientSecretEnv": "KEYCLOAK_CLIENT_SECRET",
        "keycloakUsernameEnv": "KEYCLOAK_USERNAME",
        "keycloakPasswordEnv": "KEYCLOAK_PASSWORD",
        "contextBindings": {
          "apiBaseUrl": "BASE_URL",
          "tenantId": "TENANT_ID"
        }
      },
      "runtimeContexts": [
        {
          "name": "terminal-cli",
          "mode": "terminal",
          "autoStart": true,
          "autoStopOnFinish": true,
          "startups": [
            {
              "name": "config-server",
              "command": "java",
              "args": [
                "-jar",
                "target\\spring-petclinic-config-server.jar",
                "--server.port=8888"
              ],
              "appdir": "spring-petclinic-config-server"
            },
            {
              "name": "discovery-server",
              "command": "java",
              "args": [
                "-jar",
                "target\\spring-petclinic-discovery-server.jar",
                "--server.port=8761"
              ],
              "appdir": "spring-petclinic-discovery-server"
            }
          ]
        },
        {
          "name": "docker-compose-infra",
          "mode": "docker",
          "composeFile": "docker\\docker-compose-infra.yml",
          "autoStart": false,
          "autoStopOnFinish": false
        }
      ],
      "scripts": [
        {
          "name": "keycloak-token-bootstrap",
          "phase": "postHealthcheck",
          "command": "powershell",
          "args": [
            "-NoProfile",
            "-ExecutionPolicy",
            "Bypass",
            "-File",
            ".mcpjvm\\my-project\\scripts\\refresh-keycloak-token.ps1"
          ],
          "appdir": ".",
          "envFileArg": "-EnvFile"
        }
      ],
      "executionProfiles": [
        {
          "executionProfile": "regression-test-run",
          "runtimeContextName": "docker-compose-infra",
          "executionPolicy": "stop_on_fail",
          "runtimeConfig": {
            "requestTimeoutMs": 10000,
            "retryMax": 1
          },
          "scriptRefs": [
            "keycloak-token-bootstrap"
          ],
          "plans": [
            {
              "order": 1,
              "planName": "owners-regression",
              "onFail": "inherit",
              "providedContext": {
                "tenantId": "demo"
              }
            }
          ]
        }
      ],
      "externalSystems": [
        {
          "name": "postgres",
          "kind": "database",
          "host": "localhost",
          "port": 5432,
          "healthChecks": [
            {
              "id": "tcp-open",
              "type": "tcp",
              "target": "localhost:5432",
              "required": true
            }
          ]
        },
        {
          "name": "keycloak",
          "kind": "identity",
          "host": "localhost",
          "port": 8081,
          "healthChecks": [
            {
              "id": "http-health",
              "type": "http",
              "target": "http://localhost:8081/health",
              "required": false
            }
          ]
        }
      ],
      "defaults": {
        "requestTimeoutMs": 10000,
        "retryMax": 1
      }
    }
  ]
}
