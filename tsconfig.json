{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    // File Layout
    "rootDir": ".",
    "outDir": "./dist",
    "baseUrl": ".",
    "ignoreDeprecations": "5.0",
    "paths": {
      "@/*": ["tools/transport/tools-mcp-server/src/*"],
      "@test/*": ["test/*"],
      "@tools-contracts": ["tools/contracts/tools-contracts/src/index.ts"],
      "@tools-core/*": ["tools/core/tools-core/src/*"],
      "@tools-core": ["tools/core/tools-core/src/index.ts"],
      "@tools-registry/*": ["tools/core/tools-registry/src/*"],
      "@tools-contracts/*": ["tools/contracts/tools-contracts/src/*"],
      "@tools-feature-probe": ["tools/features/probe/index.ts"],
      "@tools-feature-probe/*": ["tools/features/probe/*"],
      "@tools-feature-artifact-management": ["tools/features/artifact-management/index.ts"],
      "@tools-feature-artifact-management/*": ["tools/features/artifact-management/*"],
      "@tools-feature-execution-orchestration": ["tools/features/execution-orchestration/index.ts"],
      "@tools-feature-execution-orchestration/*": ["tools/features/execution-orchestration/*"],
      "@tools-feature-regression-suite": ["tools/features/regression-suite/index.ts"],
      "@tools-feature-regression-suite/*": ["tools/features/regression-suite/*"],
      "@tools-feature-performance-suite": ["tools/features/performance-suite/index.ts"],
      "@tools-feature-performance-suite/*": ["tools/features/performance-suite/*"],
      "@tools-feature-route-synthesis": ["tools/features/route-synthesis/index.ts"],
      "@tools-feature-route-synthesis/*": ["tools/features/route-synthesis/*"],
      "@tools-feature-transport-execution": ["tools/features/transport-execution/index.ts"],
      "@tools-feature-transport-execution/*": ["tools/features/transport-execution/*"],
      "@tools-spring-http/*": ["tools/synthesizers/tools-spring-http/src/*"],
      "@tools-export-execution-profile/*": ["tools/features/execution-profile-export/*"],
      "@tools-performance-workload-jmeter/*": ["tools/features/performance-workload-jmeter/*"],
      "@tools-regression-execution-plan-spec/*": [
        "tools/spec/regression-execution-plan-spec/src/*"
      ],
      "@tools-project-artifact-spec/*": ["tools/spec/project-artifact-spec/src/*"]
    },

    // Environment Settings
    // See also https://aka.ms/tsconfig/module
    "module": "commonjs",
    "target": "es2022",
    "types": ["node"],
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    // For nodejs:
    // "lib": ["esnext"],
    // "types": ["node"],
    // and npm install -D @types/node

    // Other Outputs
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Stricter Typechecking Options
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    // Style Options
    // "noImplicitReturns": true,
    // "noImplicitOverride": true,
    // "noUnusedLocals": true,
    // "noUnusedParameters": true,
    // "noFallthroughCasesInSwitch": true,
    // "noPropertyAccessFromIndexSignature": true,

    // Recommended Options
    "strict": true,
    "jsx": "react-jsx",
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  },
  "include": [
    "server.ts",
    "tools/transport/tools-mcp-server/src/**/*.ts",
    "tools/core/tools-core/src/**/*.ts",
    "tools/core/tools-registry/src/**/*.ts",
    "tools/contracts/tools-contracts/src/**/*.ts",
    "tools/features/*/**/*.ts",
    "tools/synthesizers/tools-spring-http/src/**/*.ts",
    "tools/features/execution-profile-export/**/*.ts",
    "tools/features/performance-workload-jmeter/**/*.ts",
    "tools/spec/regression-execution-plan-spec/src/**/*.ts",
    "tools/spec/project-artifact-spec/src/**/*.ts"
  ],
  "exclude": ["dist", "test", "node_modules"]
}
