{
  "targets": [
    {
      "type": "class_method",
      "selectors": {
        "fqcn": "com.example.social.post.app.controller.PostController",
        "method": "createPost",
        "signature": "(com.example.social.post.api.CreatePostRequest)",
        "sourceRoot": "test/fixtures/spring-apps/social-platform/post-service/post-app"
      }
    },
    {
      "type": "class_method",
      "selectors": {
        "fqcn": "com.example.social.post.app.controller.PostController",
        "method": "deletePost",
        "signature": "(java.lang.String)",
        "sourceRoot": "test/fixtures/spring-apps/social-platform/post-service/post-app"
      }
    }
  ],
  "prerequisites": [
    {
      "key": "tenantId",
      "required": true,
      "secret": false,
      "default": "tenant-social-001"
    },
    {
      "key": "auth.bearer",
      "required": true,
      "secret": true
    }
  ],
  "steps": [
    {
      "order": 1,
      "id": "create_post",
      "targetRef": 0,
      "protocol": "http",
      "transport": {
        "http": {
          "method": "POST",
          "pathTemplate": "/api/v1/posts",
          "path": {},
          "query": {
            "tenantId": "${tenantId}"
          },
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "title": "Hello World!"
          }
        }
      },
      "extract": [
        {
          "from": "response.bodyJson.id",
          "as": "postId"
        }
      ],
      "expect": [
        {
          "id": "create_post_http_status",
          "actualPath": "transport.status_code",
          "operator": "field_equals",
          "expected": 201
        }
      ]
    },
    {
      "order": 2,
      "id": "delete_post",
      "targetRef": 1,
      "protocol": "http",
      "transport": {
        "http": {
          "method": "DELETE",
          "pathTemplate": "/api/v1/posts/${postId}",
          "path": {},
          "query": {
            "tenantId": "${tenantId}"
          },
          "headers": {},
          "body": {}
        }
      },
      "expect": [
        {
          "id": "delete_post_http_status",
          "actualPath": "transport.status_code",
          "operator": "field_equals",
          "expected": 204
        }
      ]
    }
  ]
}

